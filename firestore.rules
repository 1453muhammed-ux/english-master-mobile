rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn(){ return request.auth != null; }
    function owner(uid){ return signedIn() && request.auth.uid == uid; }

    match /users/{uid} {
      allow read, create, update, delete: if owner(uid);
    }

    match /leaderboard/{uid} {
      allow read: if true;
      allow create, update, delete: if owner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 50;
    }


    match /feedback/{feedbackId} {
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          'uid','name','email','category','subject','message','uiLanguage',
          'targetLanguage','appVersion','page','status','createdAt'
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 60
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 160
        && request.resource.data.category in ['idea','bug','content','conversation','other']
        && request.resource.data.subject is string
        && request.resource.data.subject.size() >= 3
        && request.resource.data.subject.size() <= 120
        && request.resource.data.message is string
        && request.resource.data.message.size() >= 10
        && request.resource.data.message.size() <= 2000
        && request.resource.data.uiLanguage is string
        && request.resource.data.uiLanguage.size() <= 5
        && request.resource.data.targetLanguage is string
        && request.resource.data.targetLanguage.size() <= 5
        && request.resource.data.appVersion == '7.1.2'
        && request.resource.data.status == 'new'
        && request.resource.data.createdAt == request.time;
      allow read, update, delete: if false;
    }

    match /aiUsage/{uid} {
      allow read, write: if false; // Cloud Functions Admin SDK only.
    }

    match /contentUsage/{uid} {
      allow read, write: if false; // Cloud Functions Admin SDK only.
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
