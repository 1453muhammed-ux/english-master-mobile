rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function owner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function admin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role in [
          'owner',
          'admin',
          'support',
          'editor',
          'viewer'
        ]
        && (
          !get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.keys().hasAny(['active'])
          || get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active == true
        );
    }

    function feedbackManager() {
      return admin()
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role in [
          'owner',
          'admin',
          'support'
        ];
    }

    function systemOwner() {
      return admin()
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'owner';
    }

    // User profile and course progress.
    match /users/{uid} {
      allow read, create, update, delete: if owner(uid);
    }

    match /users/{uid}/{document=**} {
      allow read, write: if owner(uid);
    }

    // Public ranking for signed-in learners. Each learner may edit only their own row.
    match /leaderboard/{uid} {
      allow read: if signedIn();
      allow create, update: if owner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 50;
      allow delete: if owner(uid);
    }

    // Role-aware admin registry. Admin records are created manually by the system owner.
    // admins/<Firebase UID> { role: "owner", active: true, displayName: "Muhammed Aslan" }
    match /admins/{uid} {
      allow read: if owner(uid);
      allow write: if false;
    }

    // Suggestions and bug reports are created by their sender.
    match /feedback/{feedbackId} {
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          'uid',
          'name',
          'email',
          'category',
          'subject',
          'message',
          'uiLanguage',
          'targetLanguage',
          'appVersion',
          'page',
          'view',
          'ticket',
          'viewport',
          'userAgent',
          'status',
          'createdAt'
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 60
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 160
        && request.resource.data.category in [
          'idea',
          'bug',
          'content',
          'conversation',
          'other'
        ]
        && request.resource.data.subject is string
        && request.resource.data.subject.size() >= 3
        && request.resource.data.subject.size() <= 120
        && request.resource.data.message is string
        && request.resource.data.message.size() >= 10
        && request.resource.data.message.size() <= 2000
        && request.resource.data.uiLanguage is string
        && request.resource.data.uiLanguage.size() <= 5
        && request.resource.data.targetLanguage is string
        && request.resource.data.targetLanguage.size() <= 5
        && request.resource.data.appVersion is string
        && request.resource.data.appVersion.size() <= 20
        && request.resource.data.page is string
        && request.resource.data.page.size() <= 100
        && request.resource.data.view is string
        && request.resource.data.view.size() <= 40
        && request.resource.data.ticket is string
        && request.resource.data.ticket.size() <= 32
        && request.resource.data.viewport is string
        && request.resource.data.viewport.size() <= 30
        && request.resource.data.userAgent is string
        && request.resource.data.userAgent.size() <= 300
        && request.resource.data.status == 'new'
        && request.resource.data.createdAt == request.time;

      allow read: if admin() || (signedIn() && resource.data.uid == request.auth.uid);

      allow update: if feedbackManager()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'priority',
          'assignedTo',
          'assignedName',
          'publicReply',
          'internalNote',
          'tags',
          'updatedAt',
          'adminUid'
        ])
        && request.resource.data.status in [
          'new',
          'reviewing',
          'planned',
          'in_progress',
          'resolved',
          'closed'
        ]
        && request.resource.data.priority in [
          'low',
          'normal',
          'high',
          'critical'
        ]
        && request.resource.data.assignedTo is string
        && request.resource.data.assignedTo.size() <= 128
        && request.resource.data.assignedName is string
        && request.resource.data.assignedName.size() <= 80
        && request.resource.data.publicReply is string
        && request.resource.data.publicReply.size() <= 2000
        && request.resource.data.internalNote is string
        && request.resource.data.internalNote.size() <= 3000
        && request.resource.data.tags is list
        && request.resource.data.tags.size() <= 10
        && (
          !(request.resource.data.status in ['resolved', 'closed'])
          || request.resource.data.publicReply.size() >= 3
        )
        && request.resource.data.updatedAt == request.time
        && request.resource.data.adminUid == request.auth.uid;

      allow delete: if systemOwner();

      // Immutable history written in the same batch as each admin update.
      match /history/{historyId} {
        allow read: if admin();
        allow create: if feedbackManager()
          && request.resource.data.keys().hasOnly([
            'action',
            'changes',
            'actorUid',
            'actorName',
            'actorRole',
            'appVersion',
            'createdAt'
          ])
          && request.resource.data.action == 'feedback_updated'
          && request.resource.data.changes is list
          && request.resource.data.changes.size() > 0
          && request.resource.data.changes.size() <= 20
          && request.resource.data.actorUid == request.auth.uid
          && request.resource.data.actorName is string
          && request.resource.data.actorName.size() <= 80
          && request.resource.data.actorRole is string
          && request.resource.data.actorRole.size() <= 40
          && request.resource.data.appVersion == '9.9.2'
          && request.resource.data.createdAt == request.time;
        allow update, delete: if false;
      }
    }

    // Reserved for later server-side usage and global audit systems.
    match /aiUsage/{uid} {
      allow read, write: if false;
    }

    match /voiceUsage/{uid} {
      allow read, write: if false;
    }

    match /contentUsage/{uid} {
      allow read, write: if false;
    }

    match /adminAudit/{auditId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
